# -- Contract addresses (copy from contracts/deployments/<network>.json) --
NEXT_PUBLIC_MERCHANT_REGISTRY_TESTNET=0x...
NEXT_PUBLIC_GATEWAY_TESTNET=0x...
NEXT_PUBLIC_COLLECTOR_TESTNET=0x...
NEXT_PUBLIC_USDC_TESTNET=0x...   # from https://hsp-hackathon.hashkeymerchant.com/chains

NEXT_PUBLIC_MERCHANT_REGISTRY_MAINNET=0x...
